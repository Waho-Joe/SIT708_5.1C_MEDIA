<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph.xml"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.a51c_media.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
        <action
            android:id="@+id/action_loginFragment_to_StreamHomeFragment"
            app:destination="@id/streamHomeFragment" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.example.a51c_media.SignUpFragment"
        android:label="Sign Up">
        <action
            android:id="@+id/action_signUpFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/streamHomeFragment"
        android:name="com.example.a51c_media.StreamHomeFragment"
        android:label="Stream Home">

        <action
            android:id="@+id/action_streamHomeFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_streamHomeFragment_to_playlistFragment"
            app:destination="@id/playlistFragment" />

    </fragment>

    <fragment
        android:id="@+id/playerFragment"
        android:name="com.example.a51c_media.PlayerFragment"
        android:label="Player" />
    <fragment
        android:id="@+id/playlistFragment"
        android:name="com.example.a51c_media.PlaylistFragment"
        android:label="Playlist">

        <action
            android:id="@+id/action_playlistFragment_to_playerFragment"
            app:destination="@id/playerFragment" />

    </fragment>

</navigation>